{
  "name": "@playtiss/retcon",
  "version": "0.6.1",
  "type": "module",
  "description": "Retcon for AI conversations. The AI recontextualizes its own past via MCP tools. Canonical Observer Actor instantiation of the Collaboration Protocol.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WujiLabs/playtiss.git",
    "directory": "playtiss-proxy"
  },
  "homepage": "https://github.com/WujiLabs/playtiss/tree/master/playtiss-proxy",
  "keywords": [
    "retcon",
    "playtiss",
    "claude",
    "claude-code",
    "mcp",
    "fork",
    "branch",
    "anthropic",
    "event-sourcing",
    "collaboration-protocol"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "retcon": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo",
    "prebuild": "npm run clean",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint --fix 'src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "node -e \"if(!String(process.env.npm_config_user_agent||'').startsWith('pnpm')){console.error('\\x1b[31m✗ Use `pnpm publish`, not `npm publish`. npm does NOT resolve pnpm catalog: dep specifiers — we shipped @playtiss/core@0.3.0 broken on 2026-05-27 because of this.\\x1b[0m');process.exit(1)}\""
  },
  "dependencies": {
    "@playtiss/core": "workspace:*",
    "better-sqlite3": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@stylistic/eslint-plugin": "catalog:",
    "@types/better-sqlite3": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "globals": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
