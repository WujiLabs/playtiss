{
  "name": "@playtiss/compiler",
  "version": "0.1.0",
  "description": "Playtiss Flavored Markdown (PFM) compiler for workflow definitions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist && rm -f tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "dev": "tsc --watch"
  },
  "keywords": [
    "playtiss",
    "compiler",
    "markdown",
    "workflow",
    "dag"
  ],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "@playtiss/core": "workspace:*",
    "playtiss": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
