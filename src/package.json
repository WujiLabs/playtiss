{
  "name": "playtiss",
  "version": "0.5.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./asset-store": {
      "types": "./dist/asset-store/index.d.ts",
      "import": "./dist/asset-store/index.js"
    },
    "./asset-store/storage-factory": {
      "types": "./dist/asset-store/storage-factory.d.ts",
      "import": "./dist/asset-store/storage-factory.js"
    },
    "./asset-store/local": {
      "types": "./dist/asset-store/local/index.d.ts",
      "import": "./dist/asset-store/local/index.js"
    },
    "./asset-store/s3": {
      "types": "./dist/asset-store/s3/index.d.ts",
      "import": "./dist/asset-store/s3/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./pipeline": {
      "types": "./dist/pipeline/index.d.ts",
      "import": "./dist/pipeline/index.js"
    },
    "./pipeline/parser": {
      "types": "./dist/pipeline/parser.d.ts",
      "import": "./dist/pipeline/parser.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "catalog:",
    "@aws-sdk/credential-providers": "catalog:",
    "@aws-sdk/s3-request-presigner": "catalog:",
    "@ipld/dag-json": "catalog:",
    "@playtiss/core": "workspace:*",
    "@smithy/types": "catalog:",
    "multiformats": "catalog:"
  },
  "optionalDependencies": {
    "better-sqlite3": "catalog:",
    "dotenv": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@ipld/dag-cbor": "catalog:",
    "@stylistic/eslint-plugin": "catalog:",
    "@types/better-sqlite3": "catalog:",
    "@types/fs-extra": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "fs-extra": "^11.3.4",
    "globals": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
